# DEF-CAI Environment Configuration
# Copy to .env and customize

# --- Module Identity ---
ANIMA_MODULE_NAME=def-cai
ANIMA_MODULE_VERSION=0.1.0
ANIMA_HF_REPO=ilessio-aiflowlab/project_def_cai
ANIMA_SERVE_PORT=8080

# --- LLM Backend ---
DEF_CAI_MODEL_BACKEND=openai
DEF_CAI_MODEL_NAME=gpt-4o-2024-11-20
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# --- Runtime ---
DEF_CAI_TOOL_POLICY=restricted
DEF_CAI_MAX_TURNS=100
DEF_CAI_TOOL_TIMEOUT_SECONDS=120
DEF_CAI_TRACING_ENABLED=true
DEF_CAI_HITL_ENABLED=true

# --- Compute ---
DEF_CAI_COMPUTE_BACKEND=auto
ANIMA_DEVICE=auto
ANIMA_WEIGHT_FORMAT=auto
ANIMA_WEIGHT_DIR=/data/weights

# --- ROS2 (optional) ---
DEF_CAI_ROS2_ENABLED=false
DEF_CAI_ROS2_DOMAIN_ID=42

# --- HuggingFace ---
# HF_TOKEN=hf_...
